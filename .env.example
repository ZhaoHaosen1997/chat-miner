# Chat-Miner 配置模板
# 复制为 .env 并修改实际值

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_MODEL_FALLBACK=qwen3.5:9b
OLLAMA_TIMEOUT=120

# GPU 分布式锁（Dashboard 8850 端口提供）
# 防止多个 GPU 应用（ComfyUI 等）同时抢占显存
GPU_LOCK_ENABLED=true
GPU_LOCK_URL=http://localhost:8850
GPU_LOCK_WHO=chat-miner
GPU_LOCK_RETRY_INTERVAL=5
GPU_LOCK_MAX_RETRIES=24

# 服务
HOST=0.0.0.0
PORT=8856
RELOAD=false

# 数据目录（上传的 JSON 文件存储）
DATA_DIR=data

# 数据库
DATABASE_PATH=data/chat_miner.db

# DeepSeek 在线模型（用于周报/月报深度推理，14B 本地模型负责脱敏消化）
# 如果留空，周报/月报会降级到本地模型
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner
DEEPSEEK_TIMEOUT=90

# 画像更新策略：每累积 N 天新数据刷新一次画像
PORTRAIT_REFRESH_DAYS=7

# 日志
LOG_DIR=logs
LOG_LEVEL=INFO
